# Copy this to .env.production and fill in real values before deploying.
# DATABASE_URL is set by docker-compose.yml — do not set it here.

NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://your-domain.com"

AI_PROVIDER="gemini"          # gemini | claude | openai
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
